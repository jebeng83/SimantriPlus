# WhatsApp Gateway Configuration Example
# Copy this to your .env file and adjust the values

# ==============================================
# WHATSAPP GATEWAY SETTINGS
# ==============================================

# URL WhatsApp Gateway Server
# Default: http://localhost:3000
WHATSAPP_GATEWAY_URL=http://localhost:3000

# API Key untuk autentikasi
# Generate random string yang aman
WHATSAPP_API_KEY=your-secure-api-key-here

# Timeout untuk HTTP requests (dalam detik)
# Default: 30
WHATSAPP_TIMEOUT=30

# Session ID default untuk WhatsApp
# Default: default
WHATSAPP_DEFAULT_SESSION=default

# ==============================================
# WHATSAPP FEATURES
# ==============================================

# Auto retry jika pengiriman gagal
# Values: true, false
WHATSAPP_AUTO_RETRY=true

# Gunakan queue untuk pengiriman pesan
# Values: true, false
WHATSAPP_QUEUE_ENABLED=false

# Enable logging pesan WhatsApp
# Values: true, false
WHATSAPP_LOG_ENABLED=true

# ==============================================
# WEBHOOK SETTINGS
# ==============================================

# URL webhook untuk menerima status pesan
# Ganti dengan domain aplikasi Anda
WHATSAPP_WEBHOOK_URL=http://your-domain.com/api/whatsapp/webhook

# ==============================================
# FILE UPLOAD SETTINGS
# ==============================================

# Maksimal ukuran file upload (dalam MB)
# Default: 10
WHATSAPP_MAX_FILE_SIZE=10

# Tipe file yang diizinkan (pisahkan dengan koma)
# Default: pdf,jpg,jpeg,png,doc,docx
WHATSAPP_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Path untuk menyimpan file sementara
# Default: storage/app/whatsapp
WHATSAPP_UPLOAD_PATH=storage/app/whatsapp

# ==============================================
# ADVANCED SETTINGS
# ==============================================

# Jumlah maksimal retry jika gagal
# Default: 3
WHATSAPP_MAX_RETRY=3

# Delay antar retry (dalam detik)
# Default: 5
WHATSAPP_RETRY_DELAY=5

# Enable debug mode untuk development
# Values: true, false
WHATSAPP_DEBUG=false

# ==============================================
# TEMPLATE SETTINGS
# ==============================================

# Prefix untuk template pesan
# Default: [EDOKTER]
WHATSAPP_MESSAGE_PREFIX="[EDOKTER]"

# Footer untuk semua pesan
# Default: Terima kasih - Tim Edokter
WHATSAPP_MESSAGE_FOOTER="Terima kasih - Tim Edokter"

# ==============================================
# RATE LIMITING
# ==============================================

# Maksimal pesan per menit
# Default: 60
WHATSAPP_RATE_LIMIT_PER_MINUTE=60

# Maksimal pesan per jam
# Default: 1000
WHATSAPP_RATE_LIMIT_PER_HOUR=1000

# ==============================================
# MONITORING & ALERTS
# ==============================================

# Email untuk notifikasi error
WHATSAPP_ALERT_EMAIL=admin@your-domain.com

# Threshold error rate untuk alert (dalam persen)
# Default: 10
WHATSAPP_ERROR_THRESHOLD=10

# ==============================================
# CONTOH KONFIGURASI PRODUCTION
# ==============================================

# Untuk production, gunakan konfigurasi seperti ini:
# WHATSAPP_GATEWAY_URL=https://wa-gateway.your-domain.com
# WHATSAPP_API_KEY=prod-secure-api-key-32-chars
# WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/whatsapp/webhook
# WHATSAPP_QUEUE_ENABLED=true
# WHATSAPP_DEBUG=false
# WHATSAPP_LOG_ENABLED=true

# ==============================================
# CONTOH KONFIGURASI DEVELOPMENT
# ==============================================

# Untuk development, gunakan konfigurasi seperti ini:
# WHATSAPP_GATEWAY_URL=http://localhost:3000
# WHATSAPP_API_KEY=dev-api-key-for-testing
# WHATSAPP_WEBHOOK_URL=http://localhost:8000/api/whatsapp/webhook
# WHATSAPP_QUEUE_ENABLED=false
# WHATSAPP_DEBUG=true
# WHATSAPP_LOG_ENABLED=true